// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS (Couple only)
// ============================================

model User {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  role  Role    @default(GROOM)
  isAdmin Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  BRIDE
  GROOM
}

// ============================================
// GUESTS (RSVP Management)
// ============================================

model Guest {
  id                 String    @id @default(uuid())
  name               String
  email              String?
  phone              String?
  side               String    @default("groom") // "bride" or "groom"
  age                Int?
  relationship       String?   // "parent", "sibling", "friend", etc.
  inviteSent         Boolean   @default(false)
  rsvpToken          String    @unique
  rsvpStatus         String    @default("pending") // "pending", "confirmed", "declined"
  plusOneCount       Int       @default(0)
  dietaryRestrictions String?
  
  // Seating
  tableId            String?
  table              Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)
  
  ceremonyRole       String?   // "usher", "reader", "flower_girl", etc.
  notes              String?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  donations          Donation[]
  messages           Message[]

  @@index([rsvpToken])
  @@index([tableId])
  @@map("guests")
}

// ============================================
// TABLES (Seating Plan)
// ============================================

model Table {
  id             String  @id @default(uuid())
  tableNumber    Int     @unique
  theme          String?
  chairsCapacity Int
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  guests         Guest[]

  @@map("tables")
}

// ============================================
// HONEYMOON FUND ITEMS
// ============================================

model FundItem {
  id                String  @id @default(uuid())
  name              String  // "Dinner in Rome"
  alias             String? // "italy-dinner"
  description       String?
  photoUrl          String?
  category          String  // "dining", "activity", "transport", "accommodation"
  price             Decimal @db.Decimal(10, 2)
  quantityAvailable Int
  quantityFunded    Int     @default(0)
  fundedAmount      Decimal @default(0) @db.Decimal(10, 2)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  donations         Donation[]
  activities        HoneymoonActivity[]

  @@index([category])
  @@map("fund_items")
}

// ============================================
// DONATIONS (Payments & Contributions)
// ============================================

model Donation {
  id                 String    @id @default(uuid())
  
  fundItemId         String
  fundItem           FundItem  @relation(fields: [fundItemId], references: [id], onDelete: Cascade)
  
  guestId            String?
  guest              Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)
  
  guestName          String?   // Visible name on site
  guestEmail         String?
  amount             Decimal   @db.Decimal(10, 2)
  isAnonymous        Boolean   @default(false)
  message            String?
  
  // Payment info
  paymentProvider    String    // "stripe", "mercado_pago"
  paymentStatus      String    @default("pending") // "pending", "completed", "failed", "refunded"
  stripeSessionId    String?
  mercadoPagoId      String?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([fundItemId])
  @@index([guestId])
  @@index([paymentStatus])
  @@map("donations")
}

// ============================================
// BUDGET ITEMS
// ============================================

model BudgetItem {
  id             String    @id @default(uuid())
  itemName       String    // "Venue rental"
  category       String    // "venue", "catering", "flowers", etc.
  estimatedCost  Decimal   @db.Decimal(10, 2)
  actualCost     Decimal?  @db.Decimal(10, 2)
  paid           Boolean   @default(false)
  
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  dueDate        DateTime?
  notes          String?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([category])
  @@index([supplierId])
  @@map("budget_items")
}

// ============================================
// TASKS / CHECKLIST
// ============================================

model TaskItem {
  id          String   @id @default(uuid())
  taskName    String
  category    String   // "planning", "payments", "confirmations", etc.
  assignedTo  String   @default("both") // "bride", "groom", "both"
  dueDate     DateTime?
  priority    String   @default("medium") // "low", "medium", "high"
  completed   Boolean  @default(false)
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([completed])
  @@map("task_items")
}

// ============================================
// VENUES
// ============================================

model Venue {
  id                String   @id @default(uuid())
  name              String
  cost              Decimal? @db.Decimal(10, 2)
  distanceKm        Int?
  packageType       String?
  availableDates    DateTime[]
  hostingCapacity   Int?
  rainPlan          String?
  rainPlanScore     Int?    // 1-10 rating
  address           String?
  visited           Boolean @default(false)
  proposalFileUrl   String?
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("venues")
}

// ============================================
// SUPPLIERS
// ============================================

model Supplier {
  id              String    @id @default(uuid())
  name            String
  category        String    // "catering", "florist", "photographer", etc.
  contactInfo     String?
  phone           String?
  email           String?
  estimatedCost   Decimal?  @db.Decimal(10, 2)
  proposalFileUrl String?
  contractFileUrl String?
  status          String    @default("prospect") // "prospect", "contacted", "quoted", "booked", "rejected"
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  budgetItems     BudgetItem[]

  @@index([category])
  @@index([status])
  @@map("suppliers")
}

// ============================================
// MESSAGES (Guest Messages)
// ============================================

model Message {
  id            String   @id @default(uuid())
  guestId       String
  guest         Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  guestName     String
  messageText   String
  isFromAdmin   Boolean  @default(false)
  
  createdAt     DateTime @default(now())

  @@index([guestId])
  @@map("messages")
}

// ============================================
// INSPIRATION IMAGES (Moodboard)
// ============================================

model InspirationImage {
  id           String   @id @default(uuid())
  imageUrl     String
  category     String   // "decor", "dress", "makeup", "flowers", "photography", "color_palette"
  notes        String?
  sourceLink   String?
  isFavorite   Boolean  @default(false)
  
  createdAt    DateTime @default(now())

  @@index([category])
  @@map("inspiration_images")
}

// ============================================
// MUSIC TRACKS
// ============================================

model MusicTrack {
  id            String   @id @default(uuid())
  title         String
  artist        String?
  category      String   // "ceremony", "cocktail", "dinner", "party"
  spotifyUrl    String?
  durationSeconds Int?
  notes         String?
  
  createdAt     DateTime @default(now())

  @@index([category])
  @@map("music_tracks")
}

// ============================================
// HONEYMOON ACTIVITIES
// ============================================

model HoneymoonActivity {
  id              String   @id @default(uuid())
  destination     String   // "Rome", "Florence", "Tuscany", etc.
  activityName    String
  activityType    String   // "tour", "restaurant", "hotel", "transport"
  estimatedCost   Decimal? @db.Decimal(10, 2)
  
  fundItemId      String?
  fundItem        FundItem? @relation(fields: [fundItemId], references: [id], onDelete: SetNull)
  
  dates           DateTime[]
  notes           String?
  bookingStatus   String   @default("not_booked") // "not_booked", "pending", "confirmed"
  bookingUrl      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([destination])
  @@index([fundItemId])
  @@map("honeymoon_activities")
}

// ============================================
// PHOTOS (Photo Gallery)
// ============================================

model Photo {
  id            String   @id @default(uuid())
  imageUrl      String
  title         String?
  description   String?
  uploadedBy    String?  // Email of person who uploaded
  category      String?  // "pre-wedding", "venue", "decor", etc.
  
  createdAt     DateTime @default(now())

  @@index([category])
  @@map("photos")
}
